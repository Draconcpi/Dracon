generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id             String          @id @default(cuid())
  name           String          @unique
  slug           String          @unique
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  portfolioItems PortfolioItem[]

  @@map("categories")
}

model PortfolioItem {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  imageUrl     String
  thumbnailUrl String?
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId   String
  tags         String[] @default([])
  featured     Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("portfolio_items")
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("messages")
}

model Service {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  description      String
  shortDescription String
  price            String?
  priceNote        String?
  features         String[] @default([])
  icon             String   @default("⭐")
  order            Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("services")
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}

// ─── Dragon Eyes / Constellation ────────────────────────────────
model ConstellationCharacter {
  id          String  @id @default(cuid())
  charId      String  @unique // e.g. "lyra", "ignis" — used as slug
  name        String
  role        String
  description String
  color       String  @default("#a855f4")
  cx          Float   @default(400)
  cy          Float   @default(200)
  imageUrl    String?
  order       Int     @default(0)
  active      Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  connectionsFrom ConstellationLine[] @relation("fromChar")
  connectionsTo   ConstellationLine[] @relation("toChar")

  @@map("constellation_characters")
}

model ConstellationLine {
  id     String @id @default(cuid())
  fromId String
  toId   String
  from   ConstellationCharacter @relation("fromChar", fields: [fromId], references: [id], onDelete: Cascade)
  to     ConstellationCharacter @relation("toChar", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@map("constellation_lines")
}

model ConstellationLore {
  id       String @id @default(cuid())
  title    String
  text     String
  chapter  Int    @default(0)
  order    Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("constellation_lore")
}

model ConstellationGallery {
  id       String  @id @default(cuid())
  title    String
  imageUrl String?
  accent   String  @default("#a855f4")
  order    Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("constellation_gallery")
}
